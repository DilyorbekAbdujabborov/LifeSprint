# GITHUB_TOKEN: Required for GitHub AI inference API (OpenAI-compatible).
# Get your token from https://github.com/settings/tokens
GITHUB_TOKEN="MY_GITHUB_TOKEN"

# POSTGRES_URL: Required for database connection.
# Neon PostgreSQL connection string.
POSTGRES_URL="postgresql://user:password@host/db?sslmode=require"

# JWT_SECRET: Used for signing auth tokens.
# Change this to a strong random string in production.
JWT_SECRET="change-me-to-a-random-secret"
