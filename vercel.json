{
  "buildCommand": "vite build && esbuild api/handler.ts --bundle --platform=node --format=esm --outfile=api/index.js --external:express --external:cookie-parser --external:dotenv --external:jsonwebtoken --external:bcryptjs --external:openai --external:@neondatabase/serverless",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  }
}
